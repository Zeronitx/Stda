#include <iostream>
#include <string>

using namespace std;

struct STUDENT {
    string NAME;
    int GROUP;
    int SES[5];
};

double getAverage(const STUDENT& s) {
    double sum = 0;
    for (int i = 0; i < 5; ++i) {
        sum += s.SES[i];
    }
    return sum / 5.0;
}

void printGoodStudents(STUDENT arr[], int n) {
    bool found = false;
    cout << "\n--- Students with average > 4.0 ---\n";
    for (int i = 0; i < n; i++) {
        if (getAverage(arr[i]) > 4.0) {
            cout << "Name: " << arr[i].NAME << ", Group: " << arr[i].GROUP << endl;
            found = true;
        }
    }
    if (!found) {
        cout << "No such students found.\n";
    }
}

bool isVowel(char c) {
    string vowels = "AEIOUYaeiouy"; 
    return vowels.find(c) != string::npos;
}

void printVowelStartStudents(STUDENT arr[], int n) {
    cout << "\n--- Students whose name starts with a vowel ---\n";
    bool found = false;
    for (int i = 0; i < n; i++) {
        if (!arr[i].NAME.empty() && isVowel(arr[i].NAME[0])) {
            cout << "Name: " << arr[i].NAME << ", Group: " << arr[i].GROUP << ", Grades: ";
            for(int j = 0; j < 5; j++) {
                cout << arr[i].SES[j] << " ";
            }
            cout << endl;
            found = true;
        }
    }
    if (!found) cout << "No such students found.\n";
}

void sortStudents(STUDENT arr[], int n) {
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (getAverage(arr[j]) > getAverage(arr[j+1])) {
                STUDENT temp = arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = temp;
            }
        }
    }
}

void printAll(STUDENT arr[], int n) {
    for (int i = 0; i < n; i++) {
        cout << arr[i].NAME << " (Group " << arr[i].GROUP << ") - Average: " << getAverage(arr[i]) << endl;
    }
}

void deleteAfterMin(STUDENT arr[], int& n) {
    if (n < 2) {
        cout << "\nArray is too small to delete an element.\n";
        return; 
    }

    int minIdx = 0;
    double minAvg = getAverage(arr[0]);

    for (int i = 1; i < n; i++) {
        double currentAvg = getAverage(arr[i]);
        if (currentAvg < minAvg) {
            minAvg = currentAvg;
            minIdx = i;
        }
    }

    if (minIdx < n - 1) { 
        for (int i = minIdx + 1; i < n - 1; i++) {
            arr[i] = arr[i+1];
        }
        n--;
        cout << "\n--- Element after the minimum has been deleted ---\n";
    } else {
        cout << "\n--- Minimum element is the last one, nothing to delete after it ---\n";
    }
}

